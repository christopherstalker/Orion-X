 codex/polish-orion-x-repo-for-open-source-release
# Global
NODE_ENV=development
LOG_LEVEL=info

# API service
# Shared
NODE_ENV=development
LOG_LEVEL=info

# API
 main
API_HOST=0.0.0.0
API_PORT=4000
API_BASE_PATH=/api/v1
DATABASE_URL=postgres://postgres:postgres@localhost:5432/orionx
REDIS_URL=redis://localhost:6379
EVENT_STORE_URL=postgres://postgres:postgres@localhost:5432/orionx_events

# Worker
WORKER_CONCURRENCY=5
WORKER_POLL_INTERVAL_MS=1000
WORKER_HEARTBEAT_INTERVAL_MS=5000

# Web
WEB_HOST=0.0.0.0
WEB_PORT=3000
PUBLIC_API_URL=http://localhost:4000
